# Configuration SAND
# Copier ce fichier en .env et adapter les valeurs

# Application
APP_NAME=SAND
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8080

# Base de données PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=sand
DB_USERNAME=sand
DB_PASSWORD=secret

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Cache et sessions
CACHE_DRIVER=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# API RH Mock (développement)
RH_API_URL=http://mock-rh:3001/api
RH_API_KEY=dev-key-123

# Frontend
VITE_API_URL=http://localhost:8080/graphql
VITE_APP_NAME=SAND
