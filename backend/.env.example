# =============================================================================
# SAND — Configuration d'environnement
# Copier ce fichier en .env et ajuster les valeurs si nécessaire.
# Les valeurs ci-dessous correspondent à l'environnement Docker par défaut.
# =============================================================================

APP_NAME=SAND
APP_ENV=local
APP_KEY=                          # Générer avec : php artisan key:generate
APP_DEBUG=false                   # true en dev local, false en production
APP_URL=http://localhost:8080

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug                   # Mettre "error" en production

# -----------------------------------------------------------------------------
# Base de données PostgreSQL (Docker)
# Hôtes Docker : "db" (app) / "127.0.0.1" (hôte avec override.yml)
# -----------------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=sand
DB_USERNAME=sand
DB_PASSWORD=secret                # Changer en production

# -----------------------------------------------------------------------------
# Session
# -----------------------------------------------------------------------------
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false             # Mettre "true" en production
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false       # Mettre "true" en production (HTTPS requis)

# -----------------------------------------------------------------------------
# Queue / Cache / Broadcast
# -----------------------------------------------------------------------------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync             # Mettre "redis" en production pour les exports async
CACHE_STORE=file

# -----------------------------------------------------------------------------
# Redis (Docker)
# -----------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null               # Configurer un mot de passe en production
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Sanctum SPA — domaines autorisés pour les cookies de session
# -----------------------------------------------------------------------------
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173

# -----------------------------------------------------------------------------
# CORS — URL du frontend
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173

# -----------------------------------------------------------------------------
# API RH externe (mock en dev, vraie URL en production)
# -----------------------------------------------------------------------------
RH_API_URL=http://mock-rh:3001/api
RH_API_KEY=dev-key-123            # Remplacer par la vraie clé en production

# -----------------------------------------------------------------------------
# GraphQL — Sécurité
# Activer en production pour masquer le schéma aux attaquants
# -----------------------------------------------------------------------------
LIGHTHOUSE_SECURITY_DISABLE_INTROSPECTION=false   # Mettre "true" en production

# -----------------------------------------------------------------------------
# Mail (log en dev — aucun mail envoyé)
# -----------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@sand.local"
MAIL_FROM_NAME="${APP_NAME}"
