{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run codegen && tsc -b && vite build",
    "build:docker": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "e2e:full": "playwright test --workers=1 --project=chromium --project=chromium-moderateur --project=chromium-admin",
    "e2e": "playwright test --workers=1 --project=chromium --project=chromium-moderateur --project=chromium-admin",
    "e2e:auth-core": "playwright test --workers=1 e2e/login.spec.ts e2e/dashboard.spec.ts e2e/acces-refuses.spec.ts --project=chromium",
    "e2e:saisie-user": "playwright test --workers=1 e2e/saisie.spec.ts e2e/absences-ev12.spec.ts --project=chromium",
    "e2e:saisie-moderation": "playwright test --workers=1 e2e/saisie-moderateur.spec.ts e2e/supervision.spec.ts --project=chromium-moderateur",
    "e2e:admin-core": "playwright test --workers=1 e2e/admin-activites.spec.ts e2e/admin-utilisateurs.spec.ts e2e/admin-configuration.spec.ts e2e/admin-projets.spec.ts e2e/admin-equipes.spec.ts --project=chromium-admin",
    "e2e:exports-notifications": "playwright test --workers=1 e2e/export.spec.ts --project=chromium-admin",
    "e2e:navigation-shell": "playwright test --workers=1 e2e/navigation.spec.ts e2e/service-overlay.spec.ts --project=chromium-admin",
    "e2e:rgpd": "playwright test --workers=1 --project=chromium-admin-rgpd",
    "e2e:headed": "playwright test --workers=1 --headed --project=chromium --project=chromium-moderateur --project=chromium-admin",
    "e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "@apollo/client": "^4.2.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@headlessui/react": "^2.2.10",
    "@heroicons/react": "^2.2.0",
    "@sentry/react": "^10.62.0",
    "date-fns": "^4.4.0",
    "graphql": "^16.14.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.1",
    "zustand": "^5.0.14"
  },
  "overrides": {
    "flatted": ">=3.4.2",
    "picomatch": ">=2.3.2",
    "brace-expansion": ">=2.0.3",
    "yaml": ">=2.8.3",
    "lodash": ">=4.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@graphql-codegen/cli": "^6.3.1",
    "@graphql-codegen/client-preset": "^5.3.0",
    "@graphql-codegen/typescript": "^5.0.10",
    "@graphql-codegen/typescript-operations": "^5.1.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^16.5.0",
    "happy-dom": "^20.10.6",
    "tailwindcss": "^4.3.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.62.1",
    "vite": "8.1.0",
    "vitest": "^4.1.9"
  }
}
